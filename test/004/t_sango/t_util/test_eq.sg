import "sango.debug" -> debug ;;
import "sango.io.stdio" -> stdio ;;
import "sango.util.eq" -> eq ;;
import "sango.util.ord.feature" -> ordf ;;

eval _main_ -> <void> {
  test
} ;;

eval test -> <void> {
  test000,
  test100,
  void$
} ;;
eval test000 -> <void> {
  3 ordf.incarnate = *O3,
  5 ordf.incarnate = *O5,
  O3 O5 eq.eq? = false$,
  O3 O5 eq.ne? = true$,
  O3 eq.hash >> debug.repr >> stdio.print_and_newline
} ;;
eval test100 -> <void> {
  (3 ordf.incarnate) eq.incarnate= *E3,
  E3 eq.fx >> ordf.fx = 3,
  void$
} ;;
